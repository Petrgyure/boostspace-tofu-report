          { "selector": "leads.cvr",        "text": "CVR %",  "type": "number" }
        ],
        "refId": "A"
      }]
    },
    {
      "id": 12, "type": "barchart", "title": "Paid Spend — Google (CZK) & LinkedIn (USD)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": { "barWidth": 0.6, "legend": { "displayMode": "list", "placement": "bottom" } },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "tofu_weekly" },
      "targets": [{
        "type": "json", "source": "url",
        "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json",
        "root_selector": "$.weeks[*]",
        "columns": [
          { "selector": "label",                 "text": "Week",              "type": "string" },
          { "selector": "paid.google.spend_czk",  "text": "Google Spend CZK",  "type": "number" },
          { "selector": "paid.linkedin.spend_usd","text": "LinkedIn Spend USD","type": "number" }
        ],
        "refId": "A"
      }]
    },
    {
      "id": 13, "type": "table", "title": "Full Weekly Dataset",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": { "sortBy": [] },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } } },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "tofu_weekly" },
      "targets": [{
        "type": "json", "source": "url",
        "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json",
        "root_selector": "$.weeks[*]",
        "columns": [
          { "selector": "label",                   "text": "Week",         "type": "string" },
          { "selector": "reach.pageviews",          "text": "Pageviews",    "type": "number" },
          { "selector": "reach.unique_visitors",    "text": "UV",           "type": "number" },
          { "selector": "leads.total_forms",        "text": "Forms",        "type": "number" },
          { "selector": "leads.cvr",                "text": "CVR%",         "type": "number" },
          { "selector": "mql.demo_meeting_booked",  "text": "Booked",       "type": "number" },
          { "selector": "mql.leady_new_lead",       "text": "Leady",        "type": "number" },
          { "selector": "paid.google.spend_czk",    "text": "G.Spend CZK",  "type": "number" },
          { "selector": "paid.linkedin.spend_usd",  "text": "LI.Spend USD", "type": "number" }
        ],
        "refId": "A"
