      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": { "barWidth": 0.6, "groupWidth": 0.7, "stacking": "none", "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [{ "matcher": { "id": "byName", "options": "Unique Visitors" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }] },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "tofu_weekly" },
      "targets": [{
        "type": "json", "source": "url",
        "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json",
        "root_selector": "$.weeks[*]",
        "columns": [
          { "selector": "label",               "text": "Week",            "type": "string" },
          { "selector": "reach.pageviews",      "text": "Pageviews",       "type": "number" },
          { "selector": "reach.unique_visitors","text": "Unique Visitors", "type": "number" }
        ],
        "refId": "A"
      }]
    },
    {
      "id": 11, "type": "barchart", "title": "Lead Funnel — Forms & CVR %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
