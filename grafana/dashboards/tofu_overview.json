{
  "__inputs": [{ "name": "DS_TOFU_WEEKLY_JSON", "label": "TOFU Weekly JSON", "type": "datasource", "pluginId": "yesoreyeram-infinity-datasource" }],
  "__requires": [{ "type": "datasource", "id": "yesoreyeram-infinity-datasource", "version": "2.0.0" }],
  "annotations": { "list": [] },
  "description": "Boost.space TOFU Marketing Report — powered by PostHog weekly.json",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Live Dashboard", "url": "https://petrgyure.github.io/boostspace-tofu-report/", "type": "link", "targetBlank": true },
    { "title": "weekly.json", "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json", "type": "link", "targetBlank": true }
  ],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Pageviews (latest week)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "tofu_weekly" },
      "targets": [{
        "type": "json", "source": "url",
        "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json",
        "root_selector": "$.weeks[-1:]",
        "columns": [{ "selector": "reach.pageviews", "text": "Pageviews", "type": "number" }],
        "refId": "A"
      }]
    },
    {
      "id": 2, "type": "stat", "title": "Unique Visitors (latest week)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "tofu_weekly" },
      "targets": [{
        "type": "json", "source": "url",
        "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json",
        "root_selector": "$.weeks[-1:]",
        "columns": [{ "selector": "reach.unique_visitors", "text": "Unique Visitors", "type": "number" }],
        "refId": "A"
      }]
    },
    {
      "id": 3, "type": "stat", "title": "Form Submissions (latest)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "tofu_weekly" },
      "targets": [{
        "type": "json", "source": "url",
        "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json",
        "root_selector": "$.weeks[-1:]",
        "columns": [{ "selector": "leads.total_forms", "text": "Forms", "type": "number" }],
        "refId": "A"
