      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "color": { "mode": "thresholds" } } },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "tofu_weekly" },
      "targets": [{
        "type": "json", "source": "url",
        "url": "https://raw.githubusercontent.com/Petrgyure/boostspace-tofu-report/main/data/weekly.json",
